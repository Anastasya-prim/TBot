# Скопируйте в .env и подставьте свой токен от @BotFather (никогда не коммитьте .env)
BOT_TOKEN=your_bot_token_here

# Redis (сессии квиза, счётчик ИД заявок З-n)
REDIS_URL=redis://127.0.0.1:6379

# --- Либо SQLite (по умолчанию), либо PostgreSQL (Yandex Cloud Managed и др.) ---
# Если задано DATABASE_URL — SQLite не используется.
# Строка из консоли Yandex Cloud (порт обычно 6432, sslmode=require):
# DATABASE_URL=postgresql://USER:PASSWORD@c-xxxxx.rw.mdb.yandexcloud.net:6432/DBNAME?sslmode=require
# Сертификат CA (скачать: https://yandex.cloud/ru/docs/managed-postgresql/operations/connect#ssl):
# PGSSLROOTCERT=/root/.postgresql/root.crt

# SQLite: файл базы, если DATABASE_URL не задан
# SQLITE_PATH=data/tbot.db

# Экспорт CSV для менеджеров: npm run export:csv (папка по умолчанию ./exports)
# EXPORT_DIR=exports

# Необязательно: числовой chat_id (не @username). Узнать: @userinfobot
# MANAGER_CHAT_ID=123456789

# Отладка: логировать входящие апдейты в консоль
# DEBUG_UPDATES=1

# Убрать постоянные строки [poll] в консоли (по умолчанию они включены для диагностики)
# SILENT_POLL=1
