# Скопируйте в .env и подставьте свой токен от @BotFather (никогда не коммитьте .env)
BOT_TOKEN=your_bot_token_here

# Redis (сессии квиза, счётчик ИД заявок З-n)
REDIS_URL=redis://127.0.0.1:6379

# --- Хранилище заявок ---
# По умолчанию: локальный SQLite (файл ./data/tbot.db). Если задан DATABASE_URL — SQLite не используется.

# SQLite (только если DATABASE_URL не задан)
# SQLITE_PATH=data/tbot.db

# --- Supabase (бесплатный PostgreSQL, данные в веб-консоли) ---
# 1. https://supabase.com → New project → задайте пароль к базе (сохраните).
# 2. Project Settings → Database:
#    - скопируйте «Connection string» → вкладка URI.
#    - используйте режим «Direct connection», хост вида db.xxxxx.supabase.co, порт 5432.
#      Не используйте Transaction pooler (порт 6543) для этого бота — с драйвером pg возможны сбои.
# 3. Подставьте пароль в строку. Символы @ # % : / ? & в пароле ломают URI — задайте в Supabase новый пароль (буквы/цифры) или URL-encode пароля.
# DATABASE_URL=postgresql://postgres:ВАШ_ПАРОЛЬ@db.xxxxx.supabase.co:5432/postgres?sslmode=verify-full
# Если Direct db.*.supabase.co без IPv4 на VPS: возьмите URI «Session pooler» в Supabase → Connect (не Direct).
# Либо IPv4 вручную: DATABASE_HOST_IPV4=1.2.3.4
# Либо если у VPS есть рабочий IPv6: DATABASE_ALLOW_IPV6=1
# PGSSLROOTCERT обычно не нужен. Если задан — к доверенным корням Node добавляется этот файл (не заменяет их).
# При ошибке TLS на старом Linux: DATABASE_SSL_USE_SYSTEM_CA=1 (плюс apt install ca-certificates).
# Только отладка при ошибке TLS: DATABASE_SSL_REJECT_UNAUTHORIZED=0

# Другой PostgreSQL (свой сервер или другой хостинг):
# DATABASE_URL=postgresql://USER:PASSWORD@host:5432/DBNAME?sslmode=require
# При необходимости: PGSSLROOTCERT=/path/to/ca.crt

# Экспорт CSV: npm run export:csv (папка по умолчанию ./exports)
# EXPORT_DIR=exports

# Необязательно: числовой chat_id (не @username). Узнать: @userinfobot
# MANAGER_CHAT_ID=123456789

# Отладка: логировать входящие апдейты в консоль
# DEBUG_UPDATES=1

# Убрать постоянные строки [poll] в консоли (по умолчанию они включены для диагностики)
# SILENT_POLL=1
